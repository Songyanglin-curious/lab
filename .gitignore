```gitignore
# =========================
# Visual Studio user files
# =========================

.vs/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# Rider / ReSharper
_ReSharper*/
*.DotSettings.user

# =========================
# Build outputs
# =========================

[Bb]in/
[Oo]bj/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Ww][Ii][Nn]32/
bld/
artifacts/

# =========================
# Logs / temporary files
# =========================

[Ll]og/
[Ll]ogs/
*.log
*.tmp
*.temp
~$*
*~

# =========================
# NuGet
# =========================

*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json

# =========================
# Test / coverage outputs
# =========================

[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml
nunit-*.xml
*.VisualState.xml
CodeCoverage/
coverage/
*.coverage
*.coveragexml

# =========================
# MSBuild logs
# =========================

*.binlog

# =========================
# Publish / deploy local files
# =========================

[Pp]ublish/
*.Publish.xml
*.pubxml.user
*.publishsettings

# =========================
# Environment / secrets
# =========================

.env
.env.*
*.pfx
*.snk

# =========================
# ASP.NET scaffolding
# =========================

ScaffoldingReadMe.txt
```
